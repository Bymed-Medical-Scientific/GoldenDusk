{
  "ConnectionStrings": {
    "DefaultConnection": "Host=localhost;Port=5432;Database=BymedDB;Username=postgres",
    "Redis": ""
  },
  "Redis": {
    "ConnectionString": ""
  },
  "Jwt": {
    "SecretKey": "",
    "Issuer": "BymedApi",
    "Audience": "BymedApi",
    "ExpirationMinutes": 60
  },
  "Email": {
    "FromAddress": "",
    "FromName": "Bymed",
    "Host": "",
    "Port": 587,
    "UseSsl": true,
    "Username": "",
    "Password": "",
    "ContactFormRecipient": "",
    "PasswordResetBaseUrl": "https://example.com/reset-password"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "https://bymed.example.com",
      "http://localhost:3000",
      "https://localhost:3000",
      "http://localhost:4200",
      "https://localhost:4200",
      "http://127.0.0.1:4200",
      "https://127.0.0.1:4200"
    ]
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "IpWhitelist": [],
    "EndpointWhitelist": [ "get:/health" ],
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      },
      {
        "Endpoint": "*",
        "Period": "1h",
        "Limit": 1000
      },
      {
        "Endpoint": "post:/api/v1/auth/(login|register|reset-password.*)",
        "Period": "15m",
        "Limit": 5
      }
    ]
  },
  "IpRateLimitPolicies": {
    "IpRules": []
  },
  "Currency": {
    "ExchangeRateApiBaseUrl": "https://api.frankfurter.app",
    "GeoIpBaseUrl": "https://ipwho.is",
    "ExchangeRatesCacheHours": 24
  },
  "AllowedHosts": "localhost;127.0.0.1;bymed.example.com",
  "Serilog": {
    "Using": ["Serilog.Sinks.Console", "Serilog.Sinks.File"],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/bymed-.log",
          "rollingInterval": "Day"
        }
      }
    ]
  }
}
