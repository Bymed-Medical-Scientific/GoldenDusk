{
  "ConnectionStrings": {
    "DefaultConnection": ""
  },
  "Jwt": {
    "SecretKey": "",
    "Issuer": "BymedApi",
    "Audience": "BymedApi",
    "ExpirationMinutes": 60
  },
  "Email": {
    "FromAddress": "",
    "FromName": "Bymed",
    "Host": "",
    "Port": 587,
    "UseSsl": true,
    "Username": "",
    "Password": "",
    "ContactFormRecipient": "",
    "PasswordResetBaseUrl": "https://example.com/reset-password"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "https://bymed.example.com",
      "http://localhost:3000"
    ]
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "IpWhitelist": [],
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 100
      },
      {
        "Endpoint": "*",
        "Period": "1h",
        "Limit": 1000
      },
      {
        "Endpoint": "post:/api/v1/auth/(login|register|reset-password.*)",
        "Period": "15m",
        "Limit": 5
      }
    ]
  },
  "Currency": {
    "ExchangeRateApiBaseUrl": "https://api.frankfurter.app",
    "GeoIpBaseUrl": "https://ipwho.is",
    "ExchangeRatesCacheHours": 24
  },
  "AllowedHosts": "*"
}
