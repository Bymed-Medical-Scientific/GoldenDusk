# Public browser-facing API origin: scheme + host + port ONLY (no /api path).
# Optional in `next dev`: defaults to http://127.0.0.1:5084 (Bymed.API HTTP from launchSettings).
# Paths like /api/v1/Products are built in code (lib/api/routes.ts). Trailing /api is stripped.
# For HTTPS in the browser (e.g. cart Secure cookies), set explicitly:
# NEXT_PUBLIC_API_URL=https://localhost:7107
NEXT_PUBLIC_API_URL=https://localhost:7107

# Server-only: override origin for Next SSR /api/bymed → API (optional). In development,
# if NEXT_PUBLIC_API_URL is https://localhost:7107, SSR automatically uses http://127.0.0.1:5084
# (Bymed.API skips HTTP→HTTPS redirect in Development so Node is not 307'd to untrusted dev TLS).
# Override if needed: BYMED_API_INTERNAL_URL=http://127.0.0.1:5084
# For HTTPS directly from Node (uses dev TLS bypass in lib/server/node-api-fetch.ts):
# BYMED_API_INTERNAL_URL=https://127.0.0.1:7107

# Set to 1 so Node (Next server) does not bypass TLS verification for https://localhost:* in dev.
# BYMED_STRICT_DEV_TLS=1

# Storefront origin (no trailing slash). Used for canonical URLs and JSON-LD.
# NEXT_PUBLIC_SITE_URL=https://www.example.com

# Optional: only if the backend version prefix is not /api/v1 (rare).
# Do not set to /api alone — that is normalized to /api/v1.
# NEXT_PUBLIC_API_BASE_PATH=/api/v1.0
