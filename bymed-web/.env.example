# Public browser-facing API origin (no trailing slash). Used by Next route
# handlers and for direct guest calls (cart, checkout, payments).
NEXT_PUBLIC_API_URL=http://localhost:5084

# Storefront origin (no trailing slash). Used for canonical URLs and JSON-LD.
# NEXT_PUBLIC_SITE_URL=https://www.example.com

# Optional: if your API uses a different version segment (e.g. /api/v1.0)
# NEXT_PUBLIC_API_BASE_PATH=/api/v1.0
