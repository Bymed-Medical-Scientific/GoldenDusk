# ─────────────────────────────────────────────────────────────────────────────
# Bymed — Docker environment template
# Copy to .env and fill in every value before running `docker compose up`.
# .env is gitignored; never commit real secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_strong_password
POSTGRES_DB=BymedDB

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Must be at least 32 characters. Generate with: openssl rand -base64 48
JWT_SECRET_KEY=CHANGE_ME_USE_A_STRONG_SECRET_OF_AT_LEAST_32_CHARS
JWT_ISSUER=BymedApi
JWT_AUDIENCE=BymedApi
JWT_EXPIRATION_MINUTES=60

# ─── Email (SMTP) ─────────────────────────────────────────────────────────────
EMAIL_FROM_ADDRESS=noreply@bymed.co.zw
EMAIL_FROM_NAME=Bymed
EMAIL_HOST=smtp.example.com
EMAIL_PORT=587
EMAIL_USE_SSL=true
EMAIL_USERNAME=noreply@bymed.co.zw
EMAIL_PASSWORD=your_smtp_password
EMAIL_CONTACT_RECIPIENT=contact@bymed.co.zw
PASSWORD_RESET_BASE_URL=https://bymed.co.zw/reset-password

# ─── CORS & public-facing origins ────────────────────────────────────────────
# Must match exactly what the browser sends in the Origin header.
# For local Docker: http://localhost:<WEB_PORT> and http://localhost:<ADMIN_PORT>
# For production: https://bymed.co.zw and https://admin.bymed.co.zw
WEB_ORIGIN=http://localhost:3000
ADMIN_ORIGIN=http://localhost:4200

# ─── Next.js storefront ───────────────────────────────────────────────────────
# Client-side API origin — baked into the browser bundle at build time.
# Must be the publicly accessible URL browsers use to reach the API.
# For local Docker: http://localhost:<API_PORT>
# For production: https://api.bymed.co.zw
NEXT_PUBLIC_API_URL=http://localhost:8080

# ─── Host port bindings ───────────────────────────────────────────────────────
API_PORT=8080
WEB_PORT=3000
ADMIN_PORT=4200

# ─── Security ─────────────────────────────────────────────────────────────────
# Semicolon-separated list of allowed Host header values for the API.
# Use * to allow all (acceptable behind a reverse proxy that validates Host).
ALLOWED_HOSTS=localhost;127.0.0.1;bymed.co.zw
